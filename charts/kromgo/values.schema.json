{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "affinity": {
      "description": "Affinity rules for pod scheduling.",
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "config": {
      "description": "kromgo's YAML config (endpoint definitions), rendered into a ConfigMap and templated through `tpl`.",
      "properties": {
        "badges": {
          "description": "Instant-value endpoints served at /badges/{id}.",
          "items": {
            "required": []
          },
          "title": "badges",
          "type": "array"
        },
        "cache": {
          "description": "Cache-Control headers sent with badge/graph responses. One policy applies to\nevery endpoint.",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Send Cache-Control headers on badge/graph responses.",
              "title": "enabled",
              "type": "boolean"
            },
            "maxAge": {
              "default": 300,
              "description": "max-age + s-maxage in seconds (ignored when cache is disabled).",
              "title": "maxAge",
              "type": "integer"
            }
          },
          "required": [],
          "title": "cache",
          "type": "object"
        },
        "defaults": {
          "description": "Defaults applied to every endpoint, each overridable per badge/graph.",
          "required": [],
          "title": "defaults",
          "type": "object"
        },
        "gallery": {
          "description": "The \"/\" gallery previews every endpoint with copy-paste Markdown. Defaults to\nenabled; set false to serve a minimal landing page instead.",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Preview every endpoint at \"/\" with copy-paste Markdown; false serves a minimal landing page.",
              "title": "enabled",
              "type": "boolean"
            }
          },
          "required": [],
          "title": "gallery",
          "type": "object"
        },
        "graphs": {
          "description": "Time-series endpoints served at /graphs/{id}.",
          "items": {
            "required": []
          },
          "title": "graphs",
          "type": "array"
        },
        "prometheus": {
          "default": "http://prometheus-operated.monitoring.svc.cluster.local:9090",
          "description": "Prometheus base URL kromgo queries; use `secret.prometheusUrl` instead when it embeds credentials.",
          "title": "prometheus",
          "type": "string"
        }
      },
      "required": [],
      "title": "config",
      "type": "object"
    },
    "deploymentAnnotations": {
      "description": "Annotations added to the deployment, (e.g. reloader.stakater.com/auto).",
      "required": [],
      "title": "deploymentAnnotations",
      "type": "object"
    },
    "existingConfigMap": {
      "default": "",
      "description": "Mount an existing ConfigMap (with a `config.yaml` key) instead of the inline `config`; takes precedence over it.",
      "title": "existingConfigMap",
      "type": "string"
    },
    "fullnameOverride": {
      "default": "",
      "description": "Override the full release name.",
      "title": "fullnameOverride",
      "type": "string"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "httpRoute": {
      "description": "Gateway API HTTPRoute — an alternative to `ingress` for clusters using the\nGateway API. Renders one HTTPRoute pointing at the app service port. Named\n`httpRoute` (not `route`) to avoid confusion with the OpenShift Route kind.",
      "properties": {
        "additionalRules": {
          "description": " - kromgo.example.com\nCustom rules prepended before the default rule (templated).",
          "items": {
            "required": []
          },
          "title": "additionalRules",
          "type": "array"
        },
        "annotations": {
          "description": "HTTPRoute annotations.",
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "apiVersion": {
          "default": "",
          "description": "HTTPRoute apiVersion; empty defaults to gateway.networking.k8s.io/v1.",
          "title": "apiVersion",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "description": "Expose the UI via a Gateway API HTTPRoute (alternative to ingress).",
          "title": "enabled",
          "type": "boolean"
        },
        "filters": {
          "description": "Filters applied to the default rule.",
          "items": {
            "required": []
          },
          "title": "filters",
          "type": "array"
        },
        "hostnames": {
          "description": " - name: gateway\n   namespace: gateway\n   sectionName: https\nHostnames matched against the Host header (templated).",
          "items": {
            "required": []
          },
          "title": "hostnames",
          "type": "array"
        },
        "httpsRedirect": {
          "default": false,
          "description": "Redirect HTTP→HTTPS (301) instead of routing to the backend (needs HTTP+HTTPS listeners).",
          "title": "httpsRedirect",
          "type": "boolean"
        },
        "kind": {
          "default": "",
          "description": "HTTPRoute kind; empty defaults to HTTPRoute.",
          "title": "kind",
          "type": "string"
        },
        "labels": {
          "description": "HTTPRoute labels.",
          "required": [],
          "title": "labels",
          "type": "object"
        },
        "matches": {
          "description": "Match conditions for the default rule.",
          "items": {
            "anyOf": [
              {
                "properties": {
                  "path": {
                    "properties": {
                      "type": {
                        "default": "PathPrefix",
                        "title": "type",
                        "type": "string"
                      },
                      "value": {
                        "default": "/",
                        "title": "value",
                        "type": "string"
                      }
                    },
                    "required": [],
                    "title": "path",
                    "type": "object"
                  }
                },
                "required": [],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "matches",
          "type": "array"
        },
        "parentRefs": {
          "description": "Gateways (and listeners) this route attaches to.",
          "items": {
            "required": []
          },
          "title": "parentRefs",
          "type": "array"
        }
      },
      "required": [],
      "title": "httpRoute",
      "type": "object"
    },
    "image": {
      "properties": {
        "digest": {
          "default": "",
          "description": "Pin the image by digest (sha256:…); when set, overrides the tag.",
          "title": "digest",
          "type": "string"
        },
        "pullPolicy": {
          "default": "IfNotPresent",
          "description": "Image pull policy.",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "ghcr.io/home-operations/kromgo",
          "description": "Image repository.",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag; defaults to the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "Image pull secrets for private registries.",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "ingress": {
      "properties": {
        "annotations": {
          "description": "Ingress annotations.",
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "className": {
          "default": "",
          "description": "IngressClass name.",
          "title": "className",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "description": "Expose the UI via an Ingress.",
          "title": "enabled",
          "type": "boolean"
        },
        "hosts": {
          "description": "Ingress hosts and their paths.",
          "items": {
            "anyOf": [
              {
                "properties": {
                  "host": {
                    "default": "kromgo.example.com",
                    "title": "host",
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "anyOf": [
                        {
                          "properties": {
                            "path": {
                              "default": "/",
                              "title": "path",
                              "type": "string"
                            },
                            "pathType": {
                              "default": "Prefix",
                              "title": "pathType",
                              "type": "string"
                            }
                          },
                          "required": [],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "paths",
                    "type": "array"
                  }
                },
                "required": [],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "hosts",
          "type": "array"
        },
        "tls": {
          "description": "Ingress TLS configuration.",
          "items": {
            "required": []
          },
          "title": "tls",
          "type": "array"
        }
      },
      "required": [],
      "title": "ingress",
      "type": "object"
    },
    "livenessProbe": {
      "description": "Liveness probe.",
      "properties": {
        "httpGet": {
          "properties": {
            "path": {
              "default": "/healthz",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": "health",
              "title": "port",
              "type": "string"
            }
          },
          "required": [],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 10,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 20,
          "title": "periodSeconds",
          "type": "integer"
        }
      },
      "required": [],
      "title": "livenessProbe",
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "serviceMonitor": {
          "properties": {
            "annotations": {
              "description": "ServiceMonitor annotations.",
              "required": [],
              "title": "annotations",
              "type": "object"
            },
            "enabled": {
              "default": false,
              "description": "Create a Prometheus Operator ServiceMonitor (requires its CRDs).",
              "title": "enabled",
              "type": "boolean"
            },
            "interval": {
              "default": "30s",
              "description": "Scrape interval.",
              "title": "interval",
              "type": "string"
            },
            "labels": {
              "description": "ServiceMonitor labels.",
              "required": [],
              "title": "labels",
              "type": "object"
            },
            "metricRelabelings": {
              "description": "Prometheus metric relabelings.",
              "items": {
                "required": []
              },
              "title": "metricRelabelings",
              "type": "array"
            },
            "path": {
              "default": "/metrics",
              "description": "Metrics path.",
              "title": "path",
              "type": "string"
            },
            "relabelings": {
              "description": "Prometheus relabelings.",
              "items": {
                "required": []
              },
              "title": "relabelings",
              "type": "array"
            },
            "scrapeTimeout": {
              "default": "10s",
              "description": "Scrape timeout.",
              "title": "scrapeTimeout",
              "type": "string"
            }
          },
          "required": [],
          "title": "serviceMonitor",
          "type": "object"
        }
      },
      "required": [],
      "title": "monitoring",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "Override the chart name used in resource names.",
      "title": "nameOverride",
      "type": "string"
    },
    "nodeSelector": {
      "description": "Node selector for pod scheduling.",
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "podAnnotations": {
      "description": "Annotations added to the pod.",
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
    "podLabels": {
      "description": "Labels added to the pod.",
      "required": [],
      "title": "podLabels",
      "type": "object"
    },
    "podSecurityContext": {
      "description": "Pod-level securityContext (runs as non-root uid/gid 65532 with the RuntimeDefault seccomp profile).",
      "properties": {
        "fsGroup": {
          "default": 65532,
          "title": "fsGroup",
          "type": "integer"
        },
        "runAsGroup": {
          "default": 65532,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 65532,
          "title": "runAsUser",
          "type": "integer"
        },
        "seccompProfile": {
          "properties": {
            "type": {
              "default": "RuntimeDefault",
              "title": "type",
              "type": "string"
            }
          },
          "required": [],
          "title": "seccompProfile",
          "type": "object"
        }
      },
      "required": [],
      "title": "podSecurityContext",
      "type": "object"
    },
    "readinessProbe": {
      "description": "Readiness probe.",
      "properties": {
        "httpGet": {
          "properties": {
            "path": {
              "default": "/readyz",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": "health",
              "title": "port",
              "type": "string"
            }
          },
          "required": [],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 5,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        }
      },
      "required": [],
      "title": "readinessProbe",
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "description": "Number of kromgo replicas (it queries Prometheus per request and is stateless behind the Service).",
      "title": "replicaCount",
      "type": "integer"
    },
    "resources": {
      "description": "Pod resource requests/limits.",
      "required": [],
      "title": "resources",
      "type": "object"
    },
    "secret": {
      "description": "Sensitive Prometheus URL — use when the endpoint embeds basic-auth credentials\nyou don't want in the ConfigMap. Provide it inline and a Secret is created, or\npoint at an existing Secret with a PROMETHEUS_URL key. Leave empty to use the\nplain `config.prometheus` above.",
      "properties": {
        "existingSecret": {
          "default": "",
          "description": "Existing Secret with a PROMETHEUS_URL key; takes precedence over the inline value below.",
          "title": "existingSecret",
          "type": "string"
        },
        "prometheusUrl": {
          "default": "",
          "description": "PROMETHEUS_URL — sensitive Prometheus URL; overrides config.prometheus when set.",
          "title": "prometheusUrl",
          "type": "string"
        }
      },
      "required": [],
      "title": "secret",
      "type": "object"
    },
    "securityContext": {
      "description": "Container securityContext (no privilege escalation, read-only root filesystem, drops ALL capabilities).",
      "properties": {
        "allowPrivilegeEscalation": {
          "default": false,
          "title": "allowPrivilegeEscalation",
          "type": "boolean"
        },
        "capabilities": {
          "properties": {
            "drop": {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  }
                ],
                "required": []
              },
              "title": "drop",
              "type": "array"
            }
          },
          "required": [],
          "title": "capabilities",
          "type": "object"
        },
        "readOnlyRootFilesystem": {
          "default": true,
          "title": "readOnlyRootFilesystem",
          "type": "boolean"
        }
      },
      "required": [],
      "title": "securityContext",
      "type": "object"
    },
    "server": {
      "description": "Server tuning — kromgo's runtime environment variables (distinct from the\nconfig file above). SERVER_HOST/PORT and HEALTH_HOST/PORT are fixed by the\nchart (the Service and probes are wired to 8080 / 8888) and not exposed here.",
      "properties": {
        "extraEnv": {
          "description": "Extra raw env vars merged into the container (advanced), e.g. GOMEMLIMIT.",
          "items": {
            "required": []
          },
          "title": "extraEnv",
          "type": "array"
        },
        "logging": {
          "default": false,
          "description": "SERVER_LOGGING — per-request access logging.",
          "title": "logging",
          "type": "boolean"
        },
        "queryTimeout": {
          "default": "30s",
          "description": "QUERY_TIMEOUT — bounds each outbound Prometheus query (Go duration).",
          "title": "queryTimeout",
          "type": "string"
        },
        "readTimeout": {
          "default": "15s",
          "description": "SERVER_READ_TIMEOUT (Go duration); \"0\" disables the read deadline.",
          "title": "readTimeout",
          "type": "string"
        },
        "writeTimeout": {
          "default": "60s",
          "description": "SERVER_WRITE_TIMEOUT (Go duration, must exceed queryTimeout); \"0\" disables it.",
          "title": "writeTimeout",
          "type": "string"
        }
      },
      "required": [],
      "title": "server",
      "type": "object"
    },
    "service": {
      "properties": {
        "metricsPort": {
          "default": 8888,
          "description": "Health + /metrics port.",
          "title": "metricsPort",
          "type": "integer"
        },
        "port": {
          "default": 8080,
          "description": "Badge / graph / gallery port.",
          "title": "port",
          "type": "integer"
        },
        "type": {
          "default": "ClusterIP",
          "description": "Service type.",
          "title": "type",
          "type": "string"
        }
      },
      "required": [],
      "title": "service",
      "type": "object"
    },
    "serviceAccount": {
      "properties": {
        "annotations": {
          "description": "Annotations for the ServiceAccount.",
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "automount": {
          "default": false,
          "description": "Automount the ServiceAccount API token (off by default: kromgo talks to Prometheus, not the cluster API).",
          "title": "automount",
          "type": "boolean"
        },
        "create": {
          "default": true,
          "description": "Create a ServiceAccount.",
          "title": "create",
          "type": "boolean"
        },
        "name": {
          "default": "",
          "description": "ServiceAccount name; generated from the release name if empty.",
          "title": "name",
          "type": "string"
        }
      },
      "required": [],
      "title": "serviceAccount",
      "type": "object"
    },
    "tests": {
      "description": "Config for the chart's `helm test` hook (a pod that curls the Service's /readyz). Used only by `helm test`, never the workload.",
      "properties": {
        "image": {
          "properties": {
            "pullPolicy": {
              "default": "IfNotPresent",
              "description": "`helm test` image pull policy.",
              "title": "pullPolicy",
              "type": "string"
            },
            "repository": {
              "default": "ghcr.io/home-operations/busybox",
              "description": "`helm test` pod image; needs a shell with wget (kromgo's own image is from scratch).",
              "title": "repository",
              "type": "string"
            },
            "tag": {
              "default": "1.38.0@sha256:7e2c04dd50ede647bf4a7a4c8dbd629dd4971cd139b9b88fb22bfc3c7a6c13df",
              "description": "`helm test` image, pinned as `tag",
              "title": "tag",
              "type": "string"
            }
          },
          "required": [],
          "title": "image",
          "type": "object"
        }
      },
      "required": [],
      "title": "tests",
      "type": "object"
    },
    "tolerations": {
      "description": "Tolerations for pod scheduling.",
      "items": {
        "required": []
      },
      "title": "tolerations",
      "type": "array"
    },
    "volumeMounts": {
      "description": "Additional volume mounts on the container.",
      "items": {
        "required": []
      },
      "title": "volumeMounts",
      "type": "array"
    },
    "volumes": {
      "description": "Additional volumes on the Deployment.",
      "items": {
        "required": []
      },
      "title": "volumes",
      "type": "array"
    }
  },
  "required": [],
  "type": "object"
}
