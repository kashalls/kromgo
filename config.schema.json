{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/home-operations/kromgo/internal/config/kromgo-config",
  "$ref": "#/$defs/KromgoConfig",
  "$defs": {
    "Badge": {
      "properties": {
        "font": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Defaults": {
      "properties": {
        "hidden": {
          "type": "boolean"
        },
        "cacheSeconds": {
          "type": "integer"
        },
        "timeseries": {
          "$ref": "#/$defs/TimeseriesConfig"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "KromgoConfig": {
      "properties": {
        "prometheus": {
          "type": "string"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/Metric"
          },
          "type": "array"
        },
        "badge": {
          "$ref": "#/$defs/Badge"
        },
        "defaults": {
          "$ref": "#/$defs/Defaults"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["metrics"]
    },
    "Metric": {
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "range": {
          "$ref": "#/$defs/RangeQuery"
        },
        "value": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "timeseries": {
          "$ref": "#/$defs/MetricTimeseriesConfig"
        },
        "cacheSeconds": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["name", "query"]
    },
    "MetricTimeseriesConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxDuration": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "RangeQuery": {
      "properties": {
        "last": {
          "type": "string"
        },
        "offset": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "reduce": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["last"]
    },
    "TimeseriesConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxDuration": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["enabled"]
    }
  }
}
