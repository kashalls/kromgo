{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/home-operations/kromgo/internal/config/kromgo-config",
  "$ref": "#/$defs/KromgoConfig",
  "$defs": {
    "Badge": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "range": {
          "$ref": "#/$defs/RangeQuery"
        },
        "value": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "style": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "gallery": {
          "$ref": "#/$defs/GallerySettings"
        },
        "cacheSeconds": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["id", "query"]
    },
    "BadgeDefaults": {
      "properties": {
        "font": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "style": {
          "type": "string"
        },
        "gallery": {
          "$ref": "#/$defs/GallerySettings"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Defaults": {
      "properties": {
        "cacheSeconds": {
          "type": "integer"
        },
        "badge": {
          "$ref": "#/$defs/BadgeDefaults"
        },
        "graph": {
          "$ref": "#/$defs/GraphDefaults"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Gallery": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "GallerySettings": {
      "properties": {
        "hidden": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Graph": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "maxDuration": {
          "type": "string"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "legend": {
          "type": "boolean"
        },
        "theme": {
          "type": "string"
        },
        "font": {
          "type": "string"
        },
        "gallery": {
          "$ref": "#/$defs/GallerySettings"
        },
        "cacheSeconds": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["id", "query"]
    },
    "GraphDefaults": {
      "properties": {
        "maxDuration": {
          "type": "string"
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "legend": {
          "type": "boolean"
        },
        "theme": {
          "type": "string"
        },
        "font": {
          "type": "string"
        },
        "gallery": {
          "$ref": "#/$defs/GallerySettings"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "KromgoConfig": {
      "properties": {
        "prometheus": {
          "type": "string"
        },
        "gallery": {
          "$ref": "#/$defs/Gallery"
        },
        "defaults": {
          "$ref": "#/$defs/Defaults"
        },
        "badges": {
          "items": {
            "$ref": "#/$defs/Badge"
          },
          "type": "array"
        },
        "graphs": {
          "items": {
            "$ref": "#/$defs/Graph"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "RangeQuery": {
      "properties": {
        "last": {
          "type": "string"
        },
        "offset": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "reduce": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": ["last"]
    }
  }
}
