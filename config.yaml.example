---
# yaml-language-server: $schema=https://raw.githubusercontent.com/kashalls/kromgo/main/config.schema.json
badge:
  font: Verdana.ttf # Relative to /kromgo - Verdana.ttf is available in the container
  size: 12
# hideAll: false  # Show all metrics on the index page (GET /) by default. Default is true (all hidden).

# history controls access to format=history and format=chart.
# Disabled by default — must explicitly opt in.
# history:
#   enabled: true
#   maxDuration: "7d"   # global cap on the time window per request. Defaults to "1h".
#                       # Supports: s, m, h, d, y — combinable: "1y30d", "7d12h"
#                       # Set to "0" to allow unlimited time windows.

metrics:
  - name: node_cpu_usage
    hidden: false   # Show this metric on the index page even when hideAll is true
    query: "round(cluster:node_cpu:ratio_rate5m * 100, 0.1)"
    prefix: ""      # Optional
    suffix: "%"     # Optional
    colors:         # Optional
      - color: "green"
        min: 0
        max: 35
      - color: "orange"
        min: 36
        max: 75
      - color: "red"
        min: 76
        max: 1000
    # history per-metric: overrides global history settings.
    # history:
    #   enabled: true      # opt this metric in even if global history.enabled is false
    #   maxDuration: "7d"  # allow up to 7 days for this metric specifically

  # Example: github stars over 30 days — useful as a format=chart sparkline in a README.
  # Requires global history.enabled: true.
  # - name: github_stars_total
  #   query: github_stars_total
  #   title: Stars
  #   history:
  #     maxDuration: "30d"   # 30 days
  #     # maxDuration: "1y"  # or 1 year
  #     # maxDuration: "0"   # or unlimited

  # Example: metric explicitly opted out of history even when globally enabled.
  # - name: some_version_metric
  #   query: some_version_info
  #   label: version
  #   history:
  #     enabled: false  # label-based metrics are not meaningful as time series
  - name: kubernetes_build_version
    query: kubernetes_build_info{service="kubernetes"}
    label: git_version
  - name: ceph_health_status
    query: ceph_health_status{}
    colors:
      - { valueOverride: 'Ok', color: "green", min: 0, max: 0 }
      - { valueOverride: 'Not good', color: "orange", min: 1, max: 1 }
      - { valueOverride: 'Whoops', color: "red", min: 2, max: 2 }
  # valueTemplate - inline Go template applied to the result before prefix/suffix
  - name: node_memory_used
    query: "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes"
    valueTemplate: "{{ . | humanBytes }}"     # 1572864 → "1.5MB"
  # valueTemplate - reference a named template defined under the top-level 'templates' key
  - name: cluster_age
    query: "floor((time() - kube_node_created) / 86400)"
    valueTemplate: "clusterAge"              # resolved via templates map below
  - name: node_uptime
    query: "time() - node_boot_time_seconds"
# Named template snippets - reference these by key in any metric's valueTemplate field
templates:
  clusterAge: "{{ . | simplifyDays }}"   # 1159 → "3y64d"
  uptime: "{{ . | humanDuration }}"      # 9000 → "2h30m"
